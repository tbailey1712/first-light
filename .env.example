# ============================================================
# First Light — Phase 1 MVP Configuration
# ============================================================
# Copy this file to .env and fill in your values
# Lines starting with # are comments
# ============================================================

# --- CrowdSec ---
# Optional enrollment key from https://app.crowdsec.net
# Allows you to see alerts in the CrowdSec console
# Leave blank for local-only detection
CROWDSEC_ENROLLMENT_KEY=

# --- SigNoz ---
# Version tags (usually leave as default)
VERSION=v0.112.0
OTELCOL_TAG=v0.142.0

# --- Telegram Notifications ---
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-bot-token-here
# Your Telegram chat ID (from @userinfobot)
TELEGRAM_CHAT_ID=your-chat-id-here

# --- LiteLLM Router (REQUIRED) ---
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=sk-1234

# --- Langfuse Observability (REQUIRED) ---
LANGFUSE_SECRET_KEY=your-secret-key
LANGFUSE_PUBLIC_KEY=your-public-key
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Model Configuration (REQUIRED - NO DEFAULTS) ---
# Available models: claude-sonnet-4-5, claude-opus-4-6, claude-haiku-4-5,
#                   gpt-5.2, gemini/gemini-3.1-pro-preview
MICRO_AGENT_MODEL=claude-sonnet-4-5
SUPERVISOR_MODEL=claude-opus-4-6
SYNTHESIS_MODEL=claude-opus-4-6
WEEKLY_MODEL=claude-opus-4-6
MONTHLY_MODEL=claude-opus-4-6

# Temperature settings (REQUIRED - NO DEFAULTS, range: 0.0-2.0)
MICRO_AGENT_TEMPERATURE=0.0
SUPERVISOR_TEMPERATURE=0.1
SYNTHESIS_TEMPERATURE=0.2

# --- ntopng API ---
NTOPNG_HOST=192.168.1.5
NTOPNG_PORT=3000
NTOPNG_USERNAME=your-username
NTOPNG_PASSWORD=your-password

# --- Proxmox VE API ---
# Proxmox server address (hostname or IP)
PROXMOX_HOST=pve.example.com
PROXMOX_PORT=8006
# API Token authentication (create at Datacenter > Permissions > API Tokens)
# Format: username@realm!tokenid (e.g., monitor@pve!metrics)
PROXMOX_TOKEN_ID=monitor@pve!metrics
# Token secret/UUID
PROXMOX_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Proxmox node name (usually 'pve')
PROXMOX_NODE=pve
# Verify SSL certificate (set to false for self-signed certs)
PROXMOX_VERIFY_SSL=false
