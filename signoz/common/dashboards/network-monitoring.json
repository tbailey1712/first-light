{
  "title": "Network Monitoring - SNMP",
  "description": "Network traffic, errors, and health metrics from Switch, pfSense, QNAP NAS, and Proxmox",
  "tags": ["network", "snmp", "infrastructure"],
  "layout": [
    {
      "id": "total-traffic",
      "title": "Total Network Traffic",
      "description": "Combined inbound and outbound traffic across all devices",
      "panelTypes": "graph",
      "query": {
        "queryType": "builder",
        "promQL": "",
        "builder": {
          "queryData": [
            {
              "aggregateOperator": "rate",
              "dataSource": "metrics",
              "queryName": "A",
              "metricName": "interface_in_octets",
              "groupBy": [],
              "legend": "Inbound (bytes/sec)",
              "functions": []
            },
            {
              "aggregateOperator": "rate",
              "dataSource": "metrics",
              "queryName": "B",
              "metricName": "interface_out_octets",
              "groupBy": [],
              "legend": "Outbound (bytes/sec)",
              "functions": []
            }
          ]
        }
      }
    },
    {
      "id": "traffic-by-device",
      "title": "Traffic by Device",
      "description": "Network traffic grouped by device",
      "panelTypes": "graph",
      "query": {
        "queryType": "builder",
        "promQL": "",
        "builder": {
          "queryData": [
            {
              "aggregateOperator": "rate",
              "dataSource": "metrics",
              "queryName": "A",
              "metricName": "interface_in_octets",
              "groupBy": ["device"],
              "legend": "{{device}} - In",
              "functions": []
            },
            {
              "aggregateOperator": "rate",
              "dataSource": "metrics",
              "queryName": "B",
              "metricName": "interface_out_octets",
              "groupBy": ["device"],
              "legend": "{{device}} - Out",
              "functions": []
            }
          ]
        }
      }
    },
    {
      "id": "switch-interfaces",
      "title": "Switch - Top Interfaces by Traffic",
      "description": "Busiest interfaces on switch.mcducklabs.com",
      "panelTypes": "graph",
      "query": {
        "queryType": "builder",
        "promQL": "",
        "builder": {
          "queryData": [
            {
              "aggregateOperator": "rate",
              "dataSource": "metrics",
              "queryName": "A",
              "metricName": "interface_in_octets",
              "filters": [
                {
                  "key": "device",
                  "op": "=",
                  "value": "switch.mcducklabs.com"
                }
              ],
              "groupBy": ["name"],
              "legend": "{{name}} - In",
              "functions": []
            }
          ]
        }
      }
